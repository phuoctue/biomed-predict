generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  PHARMACIST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String
  role        Role
  name        String
  specialty   String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  evaluations Evaluation[]
}

model Patient {
  id               String              @id @default(uuid())
  code             String              @unique
  fullName         String
  dob              DateTime
  gender           Gender
  weightKg         Float?
  heightCm         Float?
  diagnosisSummary String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  allergies        PatientAllergy[]
  medications      PatientMedication[]
  evaluations      Evaluation[]
}

model PatientAllergy {
  id         String   @id @default(uuid())
  patientId  String
  allergen   String
  severity   String?
  note       String?
  createdAt  DateTime @default(now())
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model PatientMedication {
  id          String   @id @default(uuid())
  patientId   String
  drugId      String?
  drugName    String
  dosage      String?
  frequency   String?
  startedAt   DateTime?
  endedAt     DateTime?
  isCurrent   Boolean  @default(true)
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  drug        Drug?    @relation(fields: [drugId], references: [id])

  @@index([patientId])
  @@index([drugId])
}

model Drug {
  id                String              @id @default(uuid())
  code              String              @unique
  name              String
  genericName       String?
  category          String?
  indications       String?
  contraindications String?
  sideEffects       String?
  mechanism         String?
  dosageForms       String?
  pregnancyRisk     String?
  renalAdjustment   String?
  hepaticAdjustment String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  interactionsA     DrugInteraction[]   @relation("drugA")
  interactionsB     DrugInteraction[]   @relation("drugB")
  patientMeds       PatientMedication[]
}

model DrugInteraction {
  id             String   @id @default(uuid())
  drugAId        String
  drugBId        String
  severity       String
  description    String
  clinicalEffect String?
  recommendation String?
  createdAt      DateTime @default(now())
  drugA          Drug     @relation("drugA", fields: [drugAId], references: [id], onDelete: Cascade)
  drugB          Drug     @relation("drugB", fields: [drugBId], references: [id], onDelete: Cascade)

  @@unique([drugAId, drugBId])
  @@index([drugAId])
  @@index([drugBId])
}

model Evaluation {
  id                 String             @id @default(uuid())
  patientId          String
  reviewerId         String
  summary            String
  riskLevel          String
  aiModel            String?
  recommendationJson Json?
  createdAt          DateTime           @default(now())
  patient            Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reviewer           User               @relation(fields: [reviewerId], references: [id], onDelete: Restrict)
  details            EvaluationDetail[]

  @@index([patientId])
  @@index([reviewerId])
}

model EvaluationDetail {
  id             String     @id @default(uuid())
  evaluationId   String
  drugId         String?
  checkType      String
  result         String
  reason         String?
  suggestion     String?
  confidence     Float?
  metadata       Json?
  createdAt      DateTime   @default(now())
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
}
