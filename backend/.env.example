# Backend Environment Variables Template
# Sao chép file này thành .env để chạy local

# Port cho Spring Boot
PORT=8081

# PostgreSQL Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/mediai_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=biomed-predict123
DB_POOL_MAX_SIZE=5
DB_POOL_MIN_IDLE=1

# JWT Configuration
JWT_ISSUER=MediAI
JWT_ACCESS_SECRET=change_me_access_secret_for_local_dev
JWT_REFRESH_SECRET=change_me_refresh_secret_for_local_dev
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Service Connection
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_EVALUATION_PATH=/api/v1/evaluate
AI_SERVICE_EXPLAIN_PATH=/api/v1/explain
AI_MODEL_NAME=gpt-4o-mini
AI_MODEL_VERSION=1.0

# CORS Configuration
# Khi deploy, hãy thêm domain Vercel vào danh sách này (ví dụ: https://my-vercel-app.vercel.app)
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
