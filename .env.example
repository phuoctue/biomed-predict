NODE_ENV=development

# Local Docker Postgres
POSTGRES_USER=mediai
POSTGRES_PASSWORD=mediai123
POSTGRES_DB=mediai_db
POSTGRES_PORT=5432

# Supabase PostgreSQL for shared team/dev and deployment
# Example:
# DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=biomed-predict123
DATABASE_URL=jdbc:postgresql://postgres:5432/mediai_db

BACKEND_PORT=8080
BACKEND_CONTEXT_PATH=/api
JWT_ISSUER=MediAI
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AI_SERVICE_PORT=8000
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_EVALUATION_PATH=/api/v1/evaluate
AI_SERVICE_EXPLAIN_PATH=/api/v1/explain
AI_MODEL_NAME=gpt-4o-mini
AI_MODEL_VERSION=1.0
CORS_ORIGINS=http://localhost:5173
LLM_PROVIDER=openai
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api
VITE_AI_BASE_URL=http://localhost:8000
VITE_APP_NAME=MediAI
